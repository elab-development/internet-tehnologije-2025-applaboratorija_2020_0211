APP_ENV=testing
APP_KEY=base64:testkey1234567890abcdefghijklmnop=

# SQLite in-memory: brzo, izolisano, ne dirne pravu bazu
DB_CONNECTION=sqlite
DB_DATABASE=:memory:

# Onemogući reCAPTCHA u testovima
RECAPTCHA_ENABLED=false

# Ne šalji emailove u testovima
MAIL_MAILER=array

# Cache u memoriji (za rate limiting testove)
CACHE_DRIVER=array
